  m_Script: {fileID: 11500000, guid: 37d236f34c7a8409bbcf93111859da23, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LandmarkInteractable
  landmarkId: ChildrenGrandPark
  landmarkName: "\uC11C\uC6B8\uC5B4\uB9B0\uC774\uB300\uACF5\uC6D0"
  description: "1973\uB144 \uC5B4\uB9B0\uC774\uB0A0\uC5D0 \uAC1C\uC6D0\uD55C \uB300\uD55C\uBBFC\uAD6D
    \uB300\uD45C \uAC00\uC871 \uD14C\uB9C8\uD30C\uD06C\uC785\uB2C8\uB2E4. \uB113\uC740
    \uBD80\uC9C0 \uC704\uC5D0 \uB3D9\uBB3C\uC6D0, \uC2DD\uBB3C\uC6D0, \uB180\uC774\uB3D9\uC0B0\uBFD0\uB9CC
    \uC544\uB2C8\uB77C \uC5B4\uB9B0\uC774 \uBCF5\uD569\uCCB4\uD5D8 \uACF5\uAC04\uC778
    '\uC11C\uC6B8\uC0C1\uC0C1\uB098\uB77C'\uAE4C\uC9C0 \uC54C\uCC28\uAC8C \uAC16\uCD94\uACE0
    \uC788\uC5B4 \uC0AC\uACC4\uC808 \uB0B4\uB0B4 \uC0AC\uB791\uBC1B\uB294 \uB3C4\uC2EC
    \uC18D \uD790\uB9C1 \uBA85\uC18C\uC785\uB2C8\uB2E4."
  sceneToLoad: ParkGame
