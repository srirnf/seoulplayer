  m_text: "\uC11C\uC6B8\uC5B4\uB9B0\uC774\uB300\uACF5\uC6D0\uC5D0\uC11C \uD0C8\uCD9C\uD55C
    \uB3D9\uBB3C\uB4E4\uC744 \uB2E4\uC2DC \uC6B0\uB9AC\uB85C \uBCF4\uB0B4\uC790!\n\n\xB7
    \u2190 \u2192 (\uB610\uB294 A / D) \uB85C \uC88C\uC6B0 \uC774\uB3D9\n\xB7 \uB3D9\uBB3C
    \uAC00\uAE4C\uC774\uC11C Space \uB97C \uAE38\uAC8C \uB20C\uB7EC \uCDA9\uC804
    \u2192 \uB85D\uC628\n\xB7 \uB5BC\uBA74 \uBBF8\uB2C8\uAC8C\uC784\uC774 \uB79C\uB364
    \uB4F1\uC7A5 (\uB2E4\uC74C \uC73C\uB85C \uB118\uACA8\uBCF4\uC138\uC694)\n\xB7
    \uC131\uACF5\uD558\uBA74 \uB530\uB77C\uC624\uACE0, \uC2E4\uD328\uD558\uBA74 \uC7A0\uAE50
    \uB3C4\uB9DD\uAC00\uC694\n\xB7 \uB3D9\uBB3C\uC744 \uBAA8\uC744\uC218\uB85D \uBBF8\uB2C8\uAC8C\uC784\uC774
    \uC5B4\uB824\uC6CC\uC838\uC694\n\n\uBAA8\uB4E0 \uB3D9\uBB3C\uC744 \uBAA8\uC73C\uBA74
