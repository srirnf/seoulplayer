  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LandmarkInteractable
  landmarkId: "\uBCC4\uB9C8\uB2F9\uB3C4\uC11C\uAD00"
  landmarkName: "\uBCC4\uB9C8\uB2F9\uB3C4\uC11C\uAD00"
  description: "\uCF54\uC5D1\uC2A4\uBAB0 \uC911\uC2EC\uC5D0 \uC704\uCE58\uD55C \uCD1D
    2,800\u33A1 \uADDC\uBAA8\uC758 \uC5F4\uB9B0 \uBB38\uD654 \uACF5\uAC04\uC785\uB2C8\uB2E4.
    13m \uB192\uC774\uC758 \uB300\uD615 \uC11C\uAC00 3\uAC1C\uAC00 \uC740\uC740\uD55C
    \uBD88\uBE5B\uC73C\uB85C \uACF5\uAC04\uC744 \uCC44\uC6B0\uACE0 \uC788\uC73C\uBA70,
    7\uB9CC\uC5EC \uAD8C\uC758 \uB2E4\uC591\uD55C \uB3C4\uC11C\uAC00 \uAD6C\uBE44\uB418\uC5B4
    \uC788\uC2B5\uB2C8\uB2E4. \uB204\uAD6C\uB098 \uBB34\uB8CC\uB85C \uCC45\uC744
    \uC77D\uC73C\uBA70 \uBA38\uBB34\uB97C \uC218 \uC788\uB294 \uB3C4\uC2EC \uC18D
    \uAC70\uB300\uD55C \uC11C\uC7AC\uC774\uC790 \uC27C\uD130\uC785\uB2C8\uB2E4."
  sceneToLoad: LibraryExplore
