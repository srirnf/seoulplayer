--- !u!114 &331870257
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 331870255}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 37d236f34c7a8409bbcf93111859da23, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LandmarkInteractable
  landmarkId: tower63
  landmarkName: "63\uBE4C\uB529"
  description: "\uC6B8 \uC5EC\uC758\uB3C4\uC5D0 \uC704\uCE58\uD55C 63\uBE4C\uB529\uC740
    1985\uB144 \uC644\uACF5 \uB2F9\uC2DC \uC544\uC2DC\uC544\uC5D0\uC11C \uAC00\uC7A5
    \uB192\uC740 \uBE4C\uB529\uC73C\uB85C \uC774\uB984\uC744 \uB0A0\uB9B0 \uB300\uD55C\uBBFC\uAD6D\uC758
    \uB300\uD45C \uB79C\uB4DC\uB9C8\uD06C\uC785\uB2C8\uB2E4. \uD2B9\uC218 \uB3C4\uAE08\uB41C
    \uD669\uAE08\uBE5B \uC720\uB9AC\uCC3D\uC774 \uD55C\uAC15\uACFC \uC5B4\uC6B0\uB7EC\uC838
    \uC7A5\uAD00\uC744 \uC5F0\uCD9C\uD558\uBA70, \uCD08\uACE0\uCE35 \uC804\uB9DD\uB300\uC640
    \uC218\uC871\uAD00 \uB4F1 \uC54C\uCC2C \uBB38\uD654 \uC608\uC220 \uACF5\uAC04\uC744
    \uD488\uACE0 \uC788\uB294 \uC11C\uC6B8\uC758 \uC0C1\uC9D5\uC801\uC778 \uAC74\uCD95\uBB3C\uC785\uB2C8\uB2E4."
  sceneToLoad: StartMenu
