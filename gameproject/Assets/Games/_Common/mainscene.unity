MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1632588108}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 37d236f34c7a8409bbcf93111859da23, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LandmarkInteractable
  landmarkId: artscenter
  landmarkName: "\uC608\uC220\uC758\uC804\uB2F9"
  description: "\uC11C\uC6B8 \uC11C\uCD08\uAD6C\uC5D0 \uC704\uCE58\uD55C \uC608\uC220\uC758\uC804\uB2F9\uC740
    \uC6B0\uB9AC\uB098\uB77C\uB97C \uB300\uD45C\uD558\uB294 \uCD5C\uB300 \uADDC\uBAA8\uC758
    \uBB38\uD654\uC608\uC220 \uC911\uC2EC\uC9C0\uC785\uB2C8\uB2E4. \uAC74\uCD95\uBBF8\uAC00
    \uB3CB\uBCF4\uC774\uB294 \uC624\uD398\uB77C\uD558\uC6B0\uC2A4\uB97C \uC911\uC2EC\uC73C\uB85C
    \uC815\uD1B5 \uD074\uB798\uC2DD \uC804\uC6A9 \uCF58\uC11C\uD2B8\uD640\uC778 \uC74C\uC545\uB2F9,
    \uD55C\uAC00\uB78C\uBBF8\uC220\uAD00\uACFC \uC11C\uC608\uBC15\uBB3C\uAD00 \uB4F1
    \uB2E4\uC591\uD55C \uC608\uC220 \uC7A5\uB974\uB97C \uD55C\uACF3\uC5D0\uC11C \uB9CC\uB0A0
    \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC57C\uC678 \uAD11\uC7A5\uC5D0\uC11C\uB294
    \uC2E0\uB098\uB294 \uC138\uACC4\uC74C\uC545\uBD84\uC218\uAC00 \uC6B4\uC601\uB418\uC5B4
    \uACF5\uC5F0\uC744 \uBCF4\uC9C0 \uC54A\uB354\uB77C\uB3C4 \uB204\uAD6C\uB098 \uD3B8\uC548\uD558\uAC8C
    \uCC3E\uC544\uC640 \uC608\uC220\uC758 \uC815\uCDE8\uB97C \uB9CC\uB07D\uD560 \uC218
    \uC788\uB294 \uC0C1\uC9D5\uC801\uC778 \uACF5\uAC04\uC785\uB2C8\uB2E4."
  sceneToLoad: 
